# Copy this file to secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit it.

anthropic_api_key = "sk-ant-..."

[snowflake]
account   = "dc45256.us-east-2.aws"
user      = "DBT_USER"
password  = ""           # same password as in ~/.dbt/profiles.yml
database  = "HEALTHCARE_CLAIMS"
schema    = "GOLD"
warehouse = "CLAIMS_DEV_WH"
role      = "DBT_ROLE"
